//#INCLUDE std/Base.rs
//#INCLUDE std/Random.rs
//#ENABLE_MACRO
//#DEFINE PROGNAME "Example №4 Random module"

fn main(){
	var output: SafeString = SafeString::new();

	PROGNAME -> println!();
	repeat 100 as _{
		var str: String;
		format!("{}", random_char()) -> str;
		var s: &str;
		str -> as_str() -> s;
		output.push_str(s);
	}
	format!("100 random symbols: {}", output) -> println!("{}");	
}